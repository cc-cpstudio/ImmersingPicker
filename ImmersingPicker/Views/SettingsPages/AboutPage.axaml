<controls:SettingsPageBase xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:ipicker="clr-namespace:ImmersingPicker.Helpers"
             xmlns:controls="clr-namespace:ImmersingPicker.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ImmersingPicker.Views.SettingsPages.AboutPage">
        <StackPanel Orientation="Vertical" Spacing="12">
                <Image Source="avares://ImmersingPicker/Assets/banner.png"/>
                <fa:SettingsExpander Header="软件版本" IconSource="{ipicker:FluentIconSource &#xE668;}">
                        <fa:SettingsExpander.Footer>
                                <TextBlock x:Name="VersionText"/>
                        </fa:SettingsExpander.Footer>
                </fa:SettingsExpander>
                <fa:SettingsExpander Header="应用程序" Description="重新启动或退出应用程序" IconSource="{ipicker:FluentIconSource &#xE9E3;}">
                        <fa:SettingsExpander.Footer>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="RestartButton" Content="重新启动" 
                                                        Click="RestartButton_OnClick"
                                                        Padding="16,8"/>
                                        <Button x:Name="ExitButton" Content="退出" 
                                                        Click="ExitButton_OnClick"
                                                        Padding="16,8"/>
                                </StackPanel>
                        </fa:SettingsExpander.Footer>
                </fa:SettingsExpander>
        </StackPanel>
</controls:SettingsPageBase>
