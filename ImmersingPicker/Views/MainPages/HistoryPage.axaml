<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="ImmersingPicker.Views.MainPages.HistoryPage">
    <Grid Margin="30 0 30 0" RowDefinitions="Auto,*" ColumnDefinitions="*,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" x:Name="TitleText" Text="历史记录页面" FontSize="24" FontWeight="Bold" Margin="0,20,0,10"/>
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="10">
            <Button Content="筛选"/>
            <Button Content="刷新"/>
            <Button x:Name="ClearHistoryButton" Content="清空历史记录"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" VerticalScrollBarVisibility="Auto" Margin="0,10">
            <StackPanel x:Name="HistoryItemsContainer" Margin="10" Spacing="10"/>
        </ScrollViewer>
    </Grid>
</UserControl>