<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="ImmersingPicker.Views.MainPages.HistoryPage">
    <Grid Margin="30 0 30 0" RowDefinitions="Auto,Auto,*" ColumnDefinitions="*,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" x:Name="TitleText" Text="历史记录页面" FontSize="24" FontWeight="Bold" Margin="0,20,0,10"/>
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="10">
            <Button x:Name="FilterButton" Content="筛选"/>
            <Button x:Name="ResetFilterButton" Content="重置筛选条件" IsEnabled="False"/>
            <Button x:Name="ClearHistoryButton" Content="清空历史记录"/>
        </StackPanel>
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                x:Name="FilterSummaryBorder"
                Background="#2D2D2D" 
                CornerRadius="8" 
                Padding="15,10"
                Margin="0,5,0,10"
                IsVisible="False">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock x:Name="FilterSummaryText" 
                          FontSize="14" 
                          VerticalAlignment="Center"
                          TextWrapping="Wrap"/>
                <Button x:Name="ClearFilterButton" 
                       Grid.Column="1"
                       Content="清除筛选" 
                       Padding="10,5"/>
            </Grid>
        </Border>
        <ScrollViewer Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" VerticalScrollBarVisibility="Auto" Margin="0,10">
            <StackPanel x:Name="HistoryItemsContainer" Margin="10" Spacing="10"/>
        </ScrollViewer>
    </Grid>
</UserControl>
