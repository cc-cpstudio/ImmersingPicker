<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:ipicker="clr-namespace:ImmersingPicker.Helpers"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
             x:Class="ImmersingPicker.Views.Dialogs.UpdateDialog">
    
    <StackPanel Orientation="Vertical" Spacing="16" Margin="24">
        <!-- 标题区域 -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="🔄" FontSize="32" VerticalAlignment="Center"/>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="发现新版本" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock x:Name="VersionInfoText" FontSize="14" Opacity="0.7" Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- 更新信息 -->
        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" 
                BorderThickness="1" CornerRadius="8" Padding="16">
            <StackPanel Orientation="Vertical" Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="版本:" FontWeight="SemiBold" Width="80"/>
                    <TextBlock x:Name="ReleaseVersionText"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="发布日期:" FontWeight="SemiBold" Width="80"/>
                    <TextBlock x:Name="ReleaseDateText"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="文件大小:" FontWeight="SemiBold" Width="80"/>
                    <TextBlock x:Name="FileSizeText"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 更新日志 -->
        <TextBlock Text="更新内容:" FontWeight="SemiBold" FontSize="14"/>
        <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="ReleaseNotesText" 
                       TextWrapping="Wrap" 
                       FontSize="13"
                       LineHeight="20"/>
        </ScrollViewer>

        <!-- 下载进度区域 (初始隐藏) -->
        <Border x:Name="ProgressBorder" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8" Padding="16"
                IsVisible="False">
            <StackPanel Orientation="Vertical" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Name="ProgressSpinner" Text="⏳" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ProgressStatusText" Text="准备下载..." VerticalAlignment="Center"/>
                </StackPanel>
                
                <ProgressBar x:Name="DownloadProgressBar" Minimum="0" Maximum="100" Value="0" Height="8"/>
                
                <TextBlock x:Name="ProgressDetailText" FontSize="12" Opacity="0.7"/>
            </StackPanel>
        </Border>

        <!-- 按钮区域 -->
        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="SkipVersionButton" Content="跳过此版本" 
                    Padding="16,8"
                    Click="SkipVersionButton_OnClick"/>
            <Button x:Name="LaterButton" Content="稍后提醒" 
                    Padding="16,8"
                    Click="LaterButton_OnClick"/>
            <Button x:Name="UpdateButton" Content="立即更新" 
                    Padding="24,8"
                    Classes="accent"
                    Click="UpdateButton_OnClick"/>
        </StackPanel>
    </StackPanel>
</UserControl>
