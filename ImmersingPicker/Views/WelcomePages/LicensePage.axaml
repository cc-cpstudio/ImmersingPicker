<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ipicker="clr-namespace:ImmersingPicker.Helpers"
             xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ImmersingPicker.Views.WelcomePages.LicensePage">
        <Grid RowDefinitions="*,Auto,*" ColumnDefinitions="*,Auto,*">
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" Spacing="16" HorizontalAlignment="Center">
                        <TextBlock Text="许可条款" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="您需要阅读并同意以下许可条款才可以继续使用 ImmersingPicker。" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Vertical" Spacing="8" HorizontalAlignment="Center">
                                <CheckBox x:Name="FreeSoftwareLicense" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="0" Margin="0 -5 0 0">
                                                <TextBlock Text="我已阅读并同意" VerticalAlignment="Center"/>
                                                <HyperlinkButton Content="《ImmersingPicker 开源许可》" VerticalAlignment="Center"/>
                                        </StackPanel>
                                </CheckBox>
                        </StackPanel>
                        <Button x:Name="NextButton" Foreground="Black" CornerRadius="25" Width="100" Height="50" HorizontalAlignment="Center" Click="NextButton_OnClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                        <controls:FontIcon Glyph="&#xEBE7;" FontFamily="avares://ImmersingPicker/Assets/Fonts/#FluentSystemIcons"/>
                                        <TextBlock Text="继续"/>
                                </StackPanel>
                        </Button>
                </StackPanel>
        </Grid>
</UserControl>
