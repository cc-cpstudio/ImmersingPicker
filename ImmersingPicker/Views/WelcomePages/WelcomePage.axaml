<controls:WelcomePageBase xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ipicker="clr-namespace:ImmersingPicker.Helpers"
             xmlns:facontrols="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:controls="clr-namespace:ImmersingPicker.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ImmersingPicker.Views.WelcomePages.WelcomePage"
             UseStandardLayout="False">
    <Grid RowDefinitions="*,Auto,*,Auto" ColumnDefinitions="*,Auto,*">
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Source="avares://ImmersingPicker/Assets/ipicker.png" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBlock Text="ImmersingPicker" FontSize="32" FontWeight="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <Button x:Name="StartButton" CornerRadius="25" Width="100" Height="50" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center" Click="StartButton_OnClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <facontrols:FontIcon Glyph="&#xEBE7;" FontFamily="avares://ImmersingPicker/Assets/Fonts/#FluentSystemIcons"/>
                    <TextBlock Text="开始使用"/>
                </StackPanel>
            </Button>
        </StackPanel>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Vertical" Margin="8" Spacing="8">
            <TextBlock x:Name="VersionText" HorizontalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                <HyperlinkButton Content="GitHub 仓库" Click="GithubHyperlinkButton_OnClick"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</controls:WelcomePageBase>
