<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:suspending="clr-namespace:ImmersingPicker.Views.suspendingWindow"
        mc:Ignorable="d" d:DesignWidth="40" d:DesignHeight="40"
        x:Class="ImmersingPicker.Views.EdgeIndicatorWindow"
        Width="40" Height="40"
        SystemDecorations="None"
        Topmost="True"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        TransparencyLevelHint="Transparent"
        ShowInTaskbar="False"
        CanResize="False">
    <suspending:EdgeIndicator x:Name="Indicator"/>
</Window>
