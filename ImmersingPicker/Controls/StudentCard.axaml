<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:ImmersingPicker.Controls"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="180"
             x:Class="ImmersingPicker.Controls.StudentCard"
             x:DataType="controls:StudentCard">
    <UserControl.Resources>
        <!-- 亮色模式下的卡片背景色 -->
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#CCCCCC"/>
        <!-- 鼠标悬停时的颜色 -->
        <SolidColorBrush x:Key="CardHoverBackgroundBrush" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="CardHoverBorderBrush" Color="#999999"/>
    </UserControl.Resources>
    <Border x:Name="MainBorder" Margin="5" Padding="12" CornerRadius="5"
            BorderThickness="2"
            PointerEntered="MainBorder_OnPointerEntered"
            PointerExited="MainBorder_OnPointerExited"
            PointerPressed="CardBorder_OnPointerPressed">
        <StackPanel Spacing="6">
            <!-- 学生姓名和学号 -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Student.Name}" FontSize="16" FontWeight="SemiBold" 
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <TextBlock Text="{Binding Student.Id, StringFormat='学号: {0}'}" FontSize="11" 
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>
            </StackPanel>
            
            <!-- 分隔线 -->
            <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            
            <!-- 座位信息 -->
            <TextBlock FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
                <Run Text="座位："/>
                <Run Text="{Binding Student.SeatRow, StringFormat='第{0}行'}"/>
                <Run Text="，"/>
                <Run Text="{Binding Student.SeatColumn, StringFormat='第{0}列'}"/>
            </TextBlock>
            
            <!-- 权重信息 -->
            <Grid ColumnDefinitions="*,*,*">
                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="初始权重" FontSize="10" FontWeight="Bold" 
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Text="{Binding Student.InitialWeight, StringFormat='0.00'}" FontSize="12" 
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Vertical">
                    <TextBlock Text="当前权重" FontSize="10" FontWeight="Bold" 
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Text="{Binding Student.Weight, StringFormat='0.00'}" FontSize="12" 
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Vertical">
                    <TextBlock Text="抽选次数" FontSize="10" FontWeight="Bold" 
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock Text="{Binding Student.SelectedAmount}" FontSize="12" 
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                </StackPanel>
            </Grid>
            
            <!-- 上次抽选时间 -->
            <TextBlock Text="{Binding Student.LastSelectedTime, StringFormat='上次抽选: {0:yyyy-MM-dd HH:mm}'}" 
                       FontSize="10" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       HorizontalAlignment="Right"/>
            
            <!-- 操作按钮 -->
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="编辑" Width="60" Click="EditButton_OnClick" 
                        Classes="Accent"/>
                <Button Content="删除" Width="60" Click="DeleteButton_OnClick" 
                        Classes="Danger"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
