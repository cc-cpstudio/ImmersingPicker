<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="150"
             x:Class="ImmersingPicker.Controls.ImportClazzDialog">
    <StackPanel Spacing="10" Margin="10">
        <Button x:Name="TxtButton" 
                Content="TXT文件（每行一个学生姓名）"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Click="OnTxtButtonClick"/>
        <Button x:Name="SecRandomButton" 
                Content="SecRandom格式（JSON）（未完成）"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Click="OnSecRandomButtonClick"/>
    </StackPanel>
</UserControl>
