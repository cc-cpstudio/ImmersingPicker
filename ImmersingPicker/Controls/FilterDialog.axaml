<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="700"
             x:Class="ImmersingPicker.Controls.FilterDialog">
    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="筛选条件" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <Border Background="#1F1F1F" CornerRadius="8" Padding="15">
            <StackPanel Spacing="10">
                <TextBlock Text="抽选时间区间" FontWeight="SemiBold" FontSize="14"/>
                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto,*,*" Margin="0,5,0,0">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="开始：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <CalendarDatePicker x:Name="StartDatePicker" Grid.Row="0" Grid.Column="1" 
                                       HorizontalAlignment="Stretch"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text=" " VerticalAlignment="Center" Margin="5,0"/>
                    <TimePicker x:Name="StartTimePicker" Grid.Row="0" Grid.Column="3" 
                               HorizontalAlignment="Stretch" Grid.ColumnSpan="2"/>
                    
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="结束：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <CalendarDatePicker x:Name="EndDatePicker" Grid.Row="2" Grid.Column="1" 
                                       HorizontalAlignment="Stretch"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text=" " VerticalAlignment="Center" Margin="5,0"/>
                    <TimePicker x:Name="EndTimePicker" Grid.Row="2" Grid.Column="3" 
                               HorizontalAlignment="Stretch" Grid.ColumnSpan="2"/>
                </Grid>
            </StackPanel>
        </Border>
        
        <Border Background="#1F1F1F" CornerRadius="8" Padding="15">
            <StackPanel Spacing="10">
                <TextBlock Text="抽选人数区间" FontWeight="SemiBold" FontSize="14"/>
                <Grid ColumnDefinitions="*,Auto,*" Margin="0,5,0,0">
                    <NumericUpDown x:Name="MinCountPicker" Grid.Column="0" 
                                  HorizontalAlignment="Stretch"
                                  Minimum="0" Value="0"/>
                    <TextBlock Grid.Column="1" Text=" 至 " VerticalAlignment="Center" Margin="10,0"/>
                    <NumericUpDown x:Name="MaxCountPicker" Grid.Column="2" 
                                  HorizontalAlignment="Stretch"
                                  Minimum="0" Value="0"/>
                </Grid>
            </StackPanel>
        </Border>
        
        <Border Background="#1F1F1F" CornerRadius="8" Padding="15">
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0" Text="被抽到学生" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                    <Button x:Name="SelectAllButton" Grid.Column="1" Content="全选" 
                           Padding="10,5" Margin="5,0"/>
                    <Button x:Name="DeselectAllButton" Grid.Column="2" Content="取消全选" 
                           Padding="10,5"/>
                </Grid>
                <TextBox x:Name="StudentSearchBox" Watermark="搜索学生..." 
                        Margin="0,5,0,5"/>
                <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="StudentListContainer" Spacing="5"/>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
