<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
             x:Class="ImmersingPicker.Controls.SecRandomSeatEditDialog">
    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <TextBlock Grid.Row="0" 
                   Text="请设置所有学生的座位行列（格式：行，列）"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,15"/>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="StudentsStackPanel" Spacing="10"/>
        </ScrollViewer>
        
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="0,15,0,0">
            <Button x:Name="CancelButton" Content="取消" Width="100"/>
            <Button x:Name="SaveButton" Content="确认导入" Width="100" Classes="Accent"/>
        </StackPanel>
    </Grid>
</UserControl>
