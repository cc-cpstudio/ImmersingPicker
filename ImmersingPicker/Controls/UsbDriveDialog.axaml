<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="400"
             x:Class="ImmersingPicker.Controls.UsbDriveDialog">
    <StackPanel Margin="20" Spacing="15">
        <TextBlock x:Name="DialogTitle" Text="设置校验 U 盘" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <StackPanel Spacing="8">
            <TextBlock Text="当前已设置的 U 盘：" FontWeight="SemiBold"/>
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10">
                <StackPanel x:Name="CurrentUsbDrivePanel" Spacing="5">
                    <TextBlock x:Name="CurrentUsbDriveText" Text="未设置" FontStyle="Italic"/>
                </StackPanel>
            </Border>
        </StackPanel>
        
        <StackPanel Spacing="8">
            <TextBlock Text="可用的 U 盘：" FontWeight="SemiBold"/>
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="10">
                <StackPanel Spacing="10">
                    <ScrollViewer Height="150" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="UsbDriveListContainer" Spacing="5"/>
                    </ScrollViewer>
                    <Button x:Name="RefreshButton" Content="刷新 U 盘列表" 
                            HorizontalAlignment="Right" Padding="15,5"/>
                </StackPanel>
            </Border>
        </StackPanel>
        
        <TextBlock x:Name="ErrorTextBlock" 
                   Text="" 
                   Foreground="Red" 
                   FontSize="12"
                   TextWrapping="Wrap"
                   IsVisible="False"/>
        
        <TextBlock x:Name="InfoTextBlock" 
                   Text="请选择一个 U 盘作为校验 U 盘，系统将通过 U 盘的卷序列号进行识别。" 
                   Foreground="Gray" 
                   FontSize="12"
                   TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
