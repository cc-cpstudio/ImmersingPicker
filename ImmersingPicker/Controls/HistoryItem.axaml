<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ImmersingPicker.Controls.HistoryItem">
        <Button x:Name="Button" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                <Grid RowDefinitions="*,*" Margin="5">
                        <TextBlock x:Name="TimeText" Grid.Row="0" FontWeight="DemiBold" FontSize="16" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="AmountText" Grid.Row="1" FontWeight="Regular" FontSize="12" HorizontalAlignment="Left"/>
                </Grid>
        </Button>
</UserControl>
